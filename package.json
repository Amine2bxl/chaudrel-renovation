{
  "name": "chaudrel-renovation",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Site web de Chaudrel Rénovation — haut de gamme, Bruxelles & Belgique.",
  "author": "Chaudrel Rénovation <Info@chaudrel.be>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.js && node scripts/build-legal.js",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\" \"scripts/**/*.js\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx}\" \"scripts/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"scripts/**/*.js\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
